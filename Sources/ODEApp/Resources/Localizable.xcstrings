    "TALK TIME": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "TIEMPO DE PALABRA"
          }
        }
      }
    },
    "Tap Summarize to generate an on-device AI summary, key points, and action items.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulsa Resumir para generar en tu Mac un resumen de IA, puntos clave y tareas."
          }
        }
      }
    },
    "Tells remote participants apart, labeling them Speaker 1, 2… in transcripts. You can rename them afterwards. Downloads a model on first use.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Distingue a los participantes remotos, etiquetándolos como Hablante 1, 2… en las transcripciones. Puedes renombrarlos después. Descarga un modelo la primera vez."
          }
        }
      }
    },
    "Test how you'll sound": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Prueba cómo sonarás"
          }
        }
      }
    },
    "Test noise removal": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Probar la limpieza de ruido"
          }
        }
      }
    },
    "The meeting is already in this language.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La reunión ya está en este idioma."
          }
        }
      }
    },
    "The new name appears in the transcript, talk time and action items.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El nuevo nombre aparece en la transcripción, el tiempo de palabra y las tareas."
          }
        }
      }
    },
    "Toggles noise cancellation from anywhere — even mid-call with another app focused.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa la cancelación de ruido desde cualquier lugar, incluso en plena llamada con otra app en primer plano."
