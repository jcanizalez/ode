            "value": "Comenzó %@"
          }
        }
      }
    },
    "Starts ODE automatically when you log in, so the virtual devices are always ready before your first call.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre ODE automáticamente al iniciar sesión, para que los dispositivos virtuales estén listos antes de tu primera llamada."
          }
        }
      }
    },
    "Summaries, transcripts & actions": {
      "localizations": {
        "es": {
