      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Resumir"
          }
        }
      }
    },
    "Summarize the meeting to extract action items.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Resume la reunión para extraer las tareas."
          }
