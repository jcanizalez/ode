    "Speech-to-text engine. Parakeet detects the language automatically (excellent Spanish); Apple is the built-in system engine. Applies to the next meeting.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Motor de voz a texto. Parakeet detecta el idioma automáticamente (excelente español); Apple es el motor integrado del sistema. Se aplica a la próxima reunión."
          }
        }
      }
    },
    "Star": {
      "localizations": {
