    "Enable Transcripts and join a call.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa las transcripciones y únete a una llamada."
          }
        }
      }
    },
    "Experimental — currently unreliable and can leave your mic silent; leave off unless testing. Stops your mic from re-capturing speaker sound. AirPods and most headsets do their own echo cancellation, so they don't need this.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Experimental: puede dejar tu micrófono en silencio; déjalo desactivado salvo para pruebas. Evita que tu micrófono recapture el sonido de los altavoces. Los AirPods y la mayoría de los auriculares ya cancelan el eco por su cuenta."
          }
        }
      }
    },
    "Follows macOS — switches when AirPods connect": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigue a macOS: cambia al conectar los AirPods"
          }
        }
      }
    },
    "General": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "General"
          }
        }
      }
    },
