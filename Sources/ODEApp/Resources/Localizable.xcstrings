            "value": "Versión %@"
          }
        }
      }
    },
    "Who \"You\" is in meeting notes — used for \"Mentions of you\" and so notes say your name instead of \"You\". Defaults to your macOS account name.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Quién es «Tú» en las notas de reunión: se usa para «Menciones de ti» y para que las notas digan tu nombre. Por defecto, el nombre de tu cuenta de macOS."
          }
        }
      }
    },
