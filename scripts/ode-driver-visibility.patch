 static AudioServerPlugInHostRef     gPlugIn_Host                        = NULL;
 
+//	ODE: dynamic visibility for the main (visible) device.
+//
+//	The device's hidden state is runtime-mutable instead of the compile-time
+//	kDevice_IsHidden constant. The controlling app shows the device by setting
+//	the custom property kODE_VisibilitySelector to the CFString "1" and hides
+//	it with "0". While visible, the app must keep re-setting "1" every few
+//	seconds as a heartbeat; a watchdog hides the device again if the pings
+//	stop (app crashed or was killed), so users are never left with a dead,
+//	selectable device.
+#define                             kODE_VisibilitySelector             'odev'
+#define                             kODE_WatchdogIntervalSec            5
+#define                             kODE_WatchdogTimeoutSec             15.0
+static bool                         gDevice_Visible                     = !kDevice_IsHidden;
+static CFAbsoluteTime               gDevice_LastPing                    = 0;
+static dispatch_source_t            gDevice_VisibilityWatchdog          = NULL;
+
+static void ODE_NotifyHiddenChanged(void)
+{
+	if(gPlugIn_Host != NULL)
+	{
+		AudioObjectPropertyAddress theAddress = { kAudioDevicePropertyIsHidden, kAudioObjectPropertyScopeGlobal, kAudioObjectPropertyElementMain };
+		gPlugIn_Host->PropertiesChanged(gPlugIn_Host, kObjectID_Device, 1, &theAddress);
+	}
+}
+
+//	Create the (persistent) watchdog timer on first use. Must be called with
+//	gPlugIn_StateMutex held. The timer is never cancelled; its handler is a
+//	cheap staleness check every kODE_WatchdogIntervalSec.
+static void ODE_EnsureVisibilityWatchdog(void)
+{
+	if(gDevice_VisibilityWatchdog != NULL)
+	{
+		return;
+	}
+	gDevice_VisibilityWatchdog = dispatch_source_create(DISPATCH_SOURCE_TYPE_TIMER, 0, 0, dispatch_get_global_queue(DISPATCH_QUEUE_PRIORITY_DEFAULT, 0));
+	dispatch_source_set_timer(gDevice_VisibilityWatchdog, dispatch_time(DISPATCH_TIME_NOW, kODE_WatchdogIntervalSec * NSEC_PER_SEC), kODE_WatchdogIntervalSec * NSEC_PER_SEC, NSEC_PER_SEC);
+	dispatch_source_set_event_handler(gDevice_VisibilityWatchdog, ^{
+		bool theDidHide = false;
+		pthread_mutex_lock(&gPlugIn_StateMutex);
+		if(gDevice_Visible && (CFAbsoluteTimeGetCurrent() - gDevice_LastPing) > kODE_WatchdogTimeoutSec)
+		{
+			gDevice_Visible = false;
+			theDidHide = true;
+		}
+		pthread_mutex_unlock(&gPlugIn_StateMutex);
+		if(theDidHide)
+		{
+			syslog(LOG_NOTICE, "ODE driver: visibility heartbeat lost, hiding device");
+			ODE_NotifyHiddenChanged();
+		}
+	});
+	dispatch_resume(gDevice_VisibilityWatchdog);
+}
+
 
